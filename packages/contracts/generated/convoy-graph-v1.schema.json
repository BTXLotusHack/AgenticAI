{
  "$id": "https://schemas.loopin.vn/contracts/convoy-graph-v1.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "calculatedAt": {
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
      "type": "string"
    },
    "components": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "averageSpeedKmh": {
            "anyOf": [
              {
                "maximum": 300,
                "minimum": 0,
                "type": "number"
              },
              {
                "type": "null"
              }
            ]
          },
          "componentId": {
            "maxLength": 160,
            "minLength": 1,
            "type": "string"
          },
          "containsLeader": {
            "type": "boolean"
          },
          "frontBoundaryMemberId": {
            "maxLength": 160,
            "minLength": 1,
            "type": "string"
          },
          "memberIds": {
            "items": {
              "maxLength": 160,
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          },
          "rearBoundaryMemberId": {
            "maxLength": 160,
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "componentId",
          "memberIds",
          "frontBoundaryMemberId",
          "rearBoundaryMemberId",
          "containsLeader",
          "averageSpeedKmh"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "edges": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "aheadMemberId": {
            "maxLength": 160,
            "minLength": 1,
            "type": "string"
          },
          "behindMemberId": {
            "maxLength": 160,
            "minLength": 1,
            "type": "string"
          },
          "combinedUncertaintyMeters": {
            "minimum": 0,
            "type": "number"
          },
          "confidentLowerGapMeters": {
            "minimum": 0,
            "type": "number"
          },
          "etaGapSeconds": {
            "anyOf": [
              {
                "minimum": 0,
                "type": "number"
              },
              {
                "type": "null"
              }
            ]
          },
          "policyVersion": {
            "maxLength": 160,
            "minLength": 1,
            "type": "string"
          },
          "routeGapMeters": {
            "minimum": 0,
            "type": "number"
          },
          "state": {
            "enum": [
              "healthy",
              "stretched",
              "broken",
              "recovering",
              "unknown"
            ],
            "type": "string"
          },
          "stateSince": {
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
            "type": "string"
          }
        },
        "required": [
          "aheadMemberId",
          "behindMemberId",
          "routeGapMeters",
          "etaGapSeconds",
          "combinedUncertaintyMeters",
          "confidentLowerGapMeters",
          "state",
          "stateSince",
          "policyVersion"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "graphRevision": {
      "maximum": 9007199254740991,
      "minimum": 0,
      "type": "integer"
    },
    "leaderMemberId": {
      "anyOf": [
        {
          "maxLength": 160,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "orderedMemberIds": {
      "items": {
        "maxLength": 160,
        "minLength": 1,
        "type": "string"
      },
      "type": "array"
    },
    "overallState": {
      "enum": [
        "together",
        "stretched",
        "split",
        "degraded"
      ],
      "type": "string"
    },
    "policyVersion": {
      "maxLength": 160,
      "minLength": 1,
      "type": "string"
    },
    "tripId": {
      "maxLength": 160,
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "tripId",
    "leaderMemberId",
    "graphRevision",
    "calculatedAt",
    "overallState",
    "orderedMemberIds",
    "edges",
    "components",
    "policyVersion"
  ],
  "title": "ConvoyGraphV1",
  "type": "object",
  "x-schema-version": 1
}
