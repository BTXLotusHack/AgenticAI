{
  "$id": "https://schemas.loopin.vn/contracts/content-report-v1.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "createdAt": {
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
      "type": "string"
    },
    "details": {
      "anyOf": [
        {
          "maxLength": 1000,
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "reasonCode": {
      "enum": [
        "spam",
        "harassment",
        "privacy-violation",
        "misleading",
        "other"
      ],
      "type": "string"
    },
    "reporterUserId": {
      "maxLength": 160,
      "minLength": 1,
      "type": "string"
    },
    "reportId": {
      "maxLength": 160,
      "minLength": 1,
      "type": "string"
    },
    "resolution": {
      "anyOf": [
        {
          "enum": [
            "resolve-report",
            "hide-target",
            "approve-target"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "resolvedAt": {
      "anyOf": [
        {
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "resolvedByUserId": {
      "anyOf": [
        {
          "maxLength": 160,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "schemaVersion": {
      "const": 1,
      "type": "number"
    },
    "status": {
      "enum": [
        "open",
        "resolved"
      ],
      "type": "string"
    },
    "targetId": {
      "maxLength": 160,
      "minLength": 1,
      "type": "string"
    },
    "targetType": {
      "enum": [
        "place-review",
        "travel-presence"
      ],
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "reportId",
    "reporterUserId",
    "targetType",
    "targetId",
    "reasonCode",
    "details",
    "createdAt",
    "status",
    "resolvedAt",
    "resolvedByUserId",
    "resolution"
  ],
  "title": "ContentReportV1",
  "type": "object",
  "x-schema-version": 1
}
