{
  "$id": "https://schemas.loopin.vn/contracts/user-travel-profile-v1.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "accessibilityPreferences": {
      "items": {
        "maxLength": 120,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 12,
      "type": "array"
    },
    "dietaryPreferences": {
      "items": {
        "maxLength": 80,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 12,
      "type": "array"
    },
    "displayName": {
      "maxLength": 80,
      "minLength": 1,
      "type": "string"
    },
    "homeCity": {
      "anyOf": [
        {
          "maxLength": 120,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "interests": {
      "items": {
        "maxLength": 80,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 24,
      "type": "array"
    },
    "preferredLanguages": {
      "items": {
        "enum": [
          "en",
          "vi"
        ],
        "type": "string"
      },
      "maxItems": 2,
      "minItems": 1,
      "type": "array"
    },
    "schemaVersion": {
      "const": 1,
      "type": "number"
    },
    "travelStyles": {
      "items": {
        "maxLength": 80,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 12,
      "type": "array"
    },
    "updatedAt": {
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
      "type": "string"
    },
    "userId": {
      "maxLength": 160,
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "userId",
    "displayName",
    "homeCity",
    "travelStyles",
    "interests",
    "preferredLanguages",
    "dietaryPreferences",
    "accessibilityPreferences",
    "updatedAt"
  ],
  "title": "UserTravelProfileV1",
  "type": "object",
  "x-schema-version": 1
}
