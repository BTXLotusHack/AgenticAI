{
  "$id": "https://schemas.loopin.vn/contracts/tasco-place-ref-v1.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "address": {
      "maxLength": 500,
      "minLength": 1,
      "type": "string"
    },
    "categories": {
      "items": {
        "maxLength": 120,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 16,
      "minItems": 1,
      "type": "array"
    },
    "coordinates": {
      "additionalProperties": false,
      "properties": {
        "lat": {
          "maximum": 90,
          "minimum": -90,
          "type": "number"
        },
        "lon": {
          "maximum": 180,
          "minimum": -180,
          "type": "number"
        }
      },
      "required": [
        "lat",
        "lon"
      ],
      "type": "object"
    },
    "id": {
      "maxLength": 160,
      "minLength": 1,
      "type": "string"
    },
    "name": {
      "maxLength": 240,
      "minLength": 1,
      "type": "string"
    },
    "provider": {
      "const": "tasco",
      "type": "string"
    },
    "ratingSummary": {
      "additionalProperties": false,
      "properties": {
        "averageRating": {
          "maximum": 5,
          "minimum": 0,
          "type": "number"
        },
        "reviewCount": {
          "maximum": 9007199254740991,
          "minimum": 0,
          "type": "integer"
        },
        "source": {
          "const": "tasco",
          "type": "string"
        }
      },
      "required": [
        "averageRating",
        "reviewCount",
        "source"
      ],
      "type": "object"
    },
    "sourceVersion": {
      "maxLength": 160,
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "id",
    "provider",
    "name",
    "address",
    "coordinates",
    "categories",
    "sourceVersion"
  ],
  "title": "TascoPlaceRefV1",
  "type": "object",
  "x-schema-version": 1
}
