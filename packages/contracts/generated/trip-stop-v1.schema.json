{
  "$id": "https://schemas.loopin.vn/contracts/trip-stop-v1.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "locked": {
      "type": "boolean"
    },
    "notes": {
      "maxLength": 500,
      "type": "string"
    },
    "place": {
      "additionalProperties": false,
      "properties": {
        "address": {
          "maxLength": 500,
          "minLength": 1,
          "type": "string"
        },
        "categories": {
          "items": {
            "maxLength": 120,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 16,
          "minItems": 1,
          "type": "array"
        },
        "coordinates": {
          "additionalProperties": false,
          "properties": {
            "lat": {
              "maximum": 90,
              "minimum": -90,
              "type": "number"
            },
            "lon": {
              "maximum": 180,
              "minimum": -180,
              "type": "number"
            }
          },
          "required": [
            "lat",
            "lon"
          ],
          "type": "object"
        },
        "id": {
          "maxLength": 160,
          "minLength": 1,
          "type": "string"
        },
        "name": {
          "maxLength": 240,
          "minLength": 1,
          "type": "string"
        },
        "provider": {
          "const": "tasco",
          "type": "string"
        },
        "ratingSummary": {
          "additionalProperties": false,
          "properties": {
            "averageRating": {
              "maximum": 5,
              "minimum": 0,
              "type": "number"
            },
            "reviewCount": {
              "maximum": 9007199254740991,
              "minimum": 0,
              "type": "integer"
            },
            "source": {
              "const": "tasco",
              "type": "string"
            }
          },
          "required": [
            "averageRating",
            "reviewCount",
            "source"
          ],
          "type": "object"
        },
        "sourceVersion": {
          "maxLength": 160,
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "provider",
        "name",
        "address",
        "coordinates",
        "categories",
        "sourceVersion"
      ],
      "type": "object"
    },
    "plannedWindow": {
      "additionalProperties": false,
      "properties": {
        "arrivalAt": {
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
          "type": "string"
        },
        "departureAt": {
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
          "type": "string"
        }
      },
      "type": "object"
    },
    "source": {
      "enum": [
        "tasco-search",
        "leader",
        "system"
      ],
      "type": "string"
    },
    "stopId": {
      "maxLength": 160,
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "stopId",
    "place",
    "locked",
    "source"
  ],
  "title": "TripStopV1",
  "type": "object",
  "x-schema-version": 1
}
