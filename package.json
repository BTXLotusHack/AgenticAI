{
  "name": "loopin",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "infrastructure/*"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "npm run dev --workspace @loopin/web --",
    "dev:services": "npm run dev --workspace @loopin/local-dev --",
    "images:optimize": "npm run images:optimize --workspace @loopin/web",
    "build": "npm run build --workspaces --if-present",
    "preview": "npm run preview --workspace @loopin/web --",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present --",
    "test:core": "npm run test --workspace @loopin/convoy-core -- --run && npm run test --workspace @loopin/simulator -- --run",
    "simulate": "npm run simulate --workspace @loopin/simulator --",
    "test:e2e": "npm run test:e2e --workspace @loopin/web"
  }
}
